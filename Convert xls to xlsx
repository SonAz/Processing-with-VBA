Sub Convert_XLS_To_XLSX_Pro()

    Dim wb As Workbook
    Dim SourcePath As String
    Dim TargetPath As String
    Dim myFile As String
    Dim FldrPicker As FileDialog
    Dim fso As Object
    Dim fileCount As Long
    Dim startTime As Double
    
    startTime = Timer
    
    ' TẮT TOÀN BỘ UPDATE
    With Application
        .ScreenUpdating = False
        .EnableEvents = False
        .DisplayAlerts = False
        .Calculation = xlCalculationManual
        .AskToUpdateLinks = False
    End With
    
    On Error GoTo SafeExit

    ' Chọn thư mục
    Set FldrPicker = Application.FileDialog(msoFileDialogFolderPicker)
    With FldrPicker
        .Title = "Chọn thư mục chứa file .XLS"
        If .Show <> -1 Then GoTo SafeExit
        SourcePath = .SelectedItems(1) & "\"
    End With

    ' Tạo folder đích
    TargetPath = SourcePath & "Converted_XLSX\"
    
    Set fso = CreateObject("Scripting.FileSystemObject")
    If Not fso.FolderExists(TargetPath) Then
        fso.CreateFolder TargetPath
    End If

    ' Lấy file .xls
    myFile = Dir(SourcePath & "*.xls")

    Do While myFile <> ""
    
        If LCase(Right(myFile, 4)) = ".xls" Then
            
            On Error Resume Next
            
            Set wb = Workbooks.Open( _
                Filename:=SourcePath & myFile, _
                UpdateLinks:=0, _
                ReadOnly:=True, _
                AddToMru:=False)
            
            If Err.Number = 0 Then
                
                wb.SaveAs _
                    Filename:=TargetPath & _
                    Left(myFile, InStrRev(myFile, ".") - 1) & ".xlsx", _
                    FileFormat:=xlOpenXMLWorkbook
                
                wb.Close SaveChanges:=False
                fileCount = fileCount + 1
                
            End If
            
            Err.Clear
            On Error GoTo SafeExit
            
            Set wb = Nothing
        End If
        
        myFile = Dir
    Loop

    MsgBox "Đã convert: " & fileCount & " file." & vbCrLf & _
           "Thời gian: " & Format(Timer - startTime, "0.00") & " giây", _
           vbInformation

SafeExit:

    ' BẬT LẠI TOÀN BỘ
    With Application
        .ScreenUpdating = True
        .EnableEvents = True
        .DisplayAlerts = True
        .Calculation = xlCalculationAutomatic
        .AskToUpdateLinks = True
        .StatusBar = False
    End With

End Sub
